# ——— Anchor Ananya Kundu website — environment variables ———
# Copy to .env.local and fill in. NEVER commit real keys.

# Public site URL (used for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=

# Enquiry form (Web3Forms or Formspree — see README / INTEGRATIONS.md)
# Web3Forms: endpoint https://api.web3forms.com/submit + access key
# Formspree: endpoint https://formspree.io/f/<form-id> (leave access key empty)
NEXT_PUBLIC_FORM_ENDPOINT=
NEXT_PUBLIC_FORM_ACCESS_KEY=

# Google Reviews via Places API (optional upgrade — fallback cards used if empty)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=

# Instagram Graph API / oEmbed (optional upgrade — manual config used if empty)
INSTAGRAM_ACCESS_TOKEN=

# Server email provider (only if switching to a server/API-route email flow)
EMAIL_PROVIDER_API_KEY=
ENQUIRY_RECEIVER_EMAIL=ananyakundu2411@gmail.com
