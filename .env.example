# ——— Anchor Ananya Kundu website — environment variables ———
# Copy to .env.local and fill in. NEVER commit real keys.
# Full explanations: docs/ENVIRONMENT_VARIABLES.md

# Public site URL (used for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=

# Enquiry form (Web3Forms or Formspree — see README / INTEGRATIONS.md)
# Web3Forms: endpoint https://api.web3forms.com/submit + access key
# Formspree: endpoint https://formspree.io/f/<form-id> (leave access key empty)
NEXT_PUBLIC_FORM_ENDPOINT=
NEXT_PUBLIC_FORM_ACCESS_KEY=
WEB3FORMS_ACCESS_KEY=

# Database — Supabase (optional: enables lead storage, Instagram/review sync, /admin)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cron route protection (Vercel sends this for scheduled invocations)
CRON_SECRET=

# Owner curation panel at /admin (optional; needs Supabase too)
ADMIN_TOKEN=

# Instagram Graph API / oEmbed (optional upgrade — local reels used if empty)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
META_APP_ID=
META_APP_SECRET=

# Google Business Profile API (optional; access approval-gated by Google)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# Google Places API (legacy fallback for a future rating widget)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=

# Server email provider (only if switching to a server email flow)
EMAIL_PROVIDER_API_KEY=
ENQUIRY_RECEIVER_EMAIL=ananyakundu2411@gmail.com
